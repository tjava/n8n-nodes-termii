{
  "name": "n8n-nodes-termii",
  "version": "0.1.0",
  "description": "n8n community node for Termii SMS, OTP, balance, and sender ID operations",
  "keywords": [
    "n8n-community-node-package",
    "termii",
    "sms",
    "otp",
    "messaging",
    "africa"
  ],
  "license": "MIT",
  "homepage": "https://github.com/tjava/n8n-nodes-termii",
  "author": {
    "name": "Taiwo Hassan",
    "email": "devtaiwo@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjava/n8n-nodes-termii.git"
  },
  "main": "dist/nodes/Termii/Termii.node.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "lintfix": "npm run lint:fix",
    "release": "n8n-node release",
    "format": "prettier --write \"**/*.ts\""
  },
  "files": [
    "dist/**/*",
    "README.md",
    "NOTES.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TermiiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Termii/Termii.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.30.1",
    "@types/node": "^18.16.0",
    "eslint": "^9.39.1",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "change-case": "4.1.2"
  }
}
